		"svelte": "~5.43",
		"globals": "~16.5",
		"prettier": "~3.6",
		"typescript": "~5.9",
		"tailwindcss": "~4.1",
		"lint-staged": "~16.2",
		"svelte-check": "~4.3",
		"patch-package": "~8.0",
		"@lucide/svelte": "~0.553",
		"@commitlint/cli": "~20.4",
		"@tsconfig/svelte": "~5.0",
		"@tailwindcss/vite": "~4.1",
