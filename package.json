{
    "name": "magic-answers",
    "type": "module",
    "contributors": [
        "Florian Trayon (https://github.com/FlorianLeChat)",
        "Claire Mathé (https://www.linkedin.com/in/claire-math%C3%A9-ux-ui-designer-%E2%9C%AE/)"
    ],
    "license": "MIT",
    "private": true,
    "version": "1.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/FlorianLeChat/Magic-Answers.git"
    },
    "bugs": {
        "url": "https://github.com/FlorianLeChat/Magic-Answers/issues"
    },
    "devDependencies": {
        "vite": "~8.0",
        "husky": "~9.1",
        "eslint": "~9.39",
        "svelte": "~5.55",
        "globals": "~16.5",
        "prettier": "~3.8",
        "typescript": "~6.0",
        "tailwindcss": "~4.2",
        "lint-staged": "~16.4",
        "svelte-check": "~4.4",
        "@sveltejs/kit": "~2.57",
        "@lucide/svelte": "~1.8",
        "@commitlint/cli": "~20.5",
        "@tsconfig/svelte": "~5.0",
        "@tailwindcss/vite": "~4.2",
        "typescript-eslint": "~8.59",
        "eslint-plugin-svelte": "~3.17",
        "prettier-plugin-svelte": "~3.5",
        "eslint-formatter-gitlab": "~7.1",
        "@stylistic/eslint-plugin": "~5.10",
        "@sveltejs/adapter-static": "~3.0",
        "@commitlint/config-conventional": "~20.5"
    },
    "engines": {
        "node": ">=20.0",
        "npm": ">=9.6"
    },
    "scripts": {
        "dev": "vite",
        "lint": "eslint . --fix --format gitlab --ext .js,.ts,.svelte",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "build": "vite build",
        "format": "prettier --write \"**/*.{js,ts,svelte}\"",
        "preview": "vite preview",
        "prepare": "husky && svelte-kit sync || echo ''",
        "lint-staged": "lint-staged",
        "commitlint": "commitlint --edit"
    },
    "browserslist": [
        "defaults"
    ]
}
